-- === منطق السكربت ===

local function claimPart(part)
    pcall(function()
        part.Velocity = Vector3.new(0, 5, 0)
        sethiddenproperty(LocalPlayer, "SimulationRadius", 10000)
        sethiddenproperty(LocalPlayer, "MaxSimulationRadius", 10000)
    end)
end

local function freezeAndReleaseBall()
    local ball = ballPath
    if not ball then return end
    pcall(function()
        ball.Velocity = Vector3.new(0, 0, 0)
        ball.RotVelocity = Vector3.new(0, 0, 0)
        ball.Anchored = true
    end)
    task.wait(0.3)
    pcall(function()
        ball.Anchored = false
    end)
end

local currentLV = nil

local function rebuildForces()
    local ball = ballPath
    if not ball then return end
    for _, v in ipairs(ball:GetChildren()) do
        if v.Name == "XForce" then v:Destroy() end
    end
    if targetAtt then targetAtt:Destroy(); targetAtt = nil end

    local att0 = Instance.new("Attachment", ball)
    att0.Name = "XForce"
    targetAtt = Instance.new("Attachment", workspace)
    targetAtt.Name = "XForce"

    local lv = Instance.new("LinearVelocity", ball)
    lv.Name = "XForce"
    lv.Attachment0 = att0
    lv.RelativeTo = Enum.ActuatorRelativeTo.World
    lv.MaxForce = 999999999
    lv.VectorVelocity = Vector3.new(0,0,0)

    ball.CanCollide = false
    ball.Massless = true

    currentLV = lv
end

local function stop()
    isRunning = false
    transferTarget = nil
    StartBtn.Text = "▶ تفعيل الإعصار الخارق"
    StartBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    TransferBtn.Text = "📤 نقل الكرة للاعب"
    if connection then connection:Disconnect(); connection = nil end
    if targetAtt then targetAtt:Destroy(); targetAtt = nil end
    if ballPath then
        for _, v in ipairs(ballPath:GetChildren()) do
            if v.Name == "XForce" then v:Destroy() end
        end
    end
    currentLV = nil
    freezeAndReleaseBall()
end

local function start()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local ball = ballPath
    if not root or not ball then return end

    isRunning = true
    transferTarget = nil
    StartBtn.Text = "⏹ إيقاف الإعصار"
    StartBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

    -- القفزة الخاطفة لأخذ الملكية
    local originalCFrame = root.CFrame
    root.CFrame = ball.CFrame
    task.wait(pullDuration)
    claimPart(ball)
    root.CFrame = originalCFrame

    rebuildForces()

    connection = RunService.PostSimulation:Connect(function()
        if not isRunning then return end

        local ball = ballPath
        if not ball or not currentLV then return end

        local activeTarget = transferTarget or LocalPlayer
        local activeChar = activeTarget.Character
        local activeRoot = activeChar and activeChar:FindFirstChild("HumanoidRootPart")

        -- إذا اللاعب الثاني اختفى ارجع للمستخدم
        if transferTarget and not activeRoot then
            transferTarget = nil
            TransferBtn.Text = "📤 نقل الكرة للاعب"
            rebuildForces()
            return
        end

        -- إذا تحرك اللاعب الثاني بعيداً جداً ارجع للمستخدم
        if transferTarget and activeRoot then
            local myChar = LocalPlayer.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if myRoot and (activeRoot.Position - myRoot.Position).Magnitude > RETURN_DISTANCE_THRESHOLD then
                transferTarget = nil
                TransferBtn.Text = "📤 نقل الكرة للاعب"
                rebuildForces()
                return
            end
        end

        if not activeRoot then return end

        local useTransfer = (transferTarget ~= nil)
        local spd = useTransfer and TRANSFER_ORBIT_SPEED or orbitSpeed
        local rad = useTransfer and TRANSFER_ORBIT_RADIUS or orbitRadius

        local t = tick() * (spd / 5)
        local goal = activeRoot.Position + Vector3.new(math.cos(t) * rad, 1, math.sin(t) * rad)

        if targetAtt then targetAtt.WorldPosition = goal end
        currentLV.VectorVelocity = (goal - ball.Position) * 40
        ball.CanCollide = false
    end)
end

-- === أحداث الأزرار ===

StartBtn.Activated:Connect(function()
    if isRunning then stop() else start() end
end)

TransferBtn.Activated:Connect(function()
    if not isRunning then
        TransferBtn.Text = "⚠️ شغّل الإعصار أولاً"
        task.delay(2, function() TransferBtn.Text = "📤 نقل الكرة للاعب" end)
        return
    end

    local name = transferInput.Text
    if name == "" then
        TransferBtn.Text = "⚠️ اكتب اسم اللاعب"
        task.delay(2, function() TransferBtn.Text = "📤 نقل الكرة للاعب" end)
        return
    end

    local target = Players:FindFirstChild(name)
    if not target or target == LocalPlayer then
        TransferBtn.Text = "❌ اللاعب غير موجود"
        task.delay(2, function() TransferBtn.Text = "📤 نقل الكرة للاعب" end)
        return
    end

    local targetChar = target.Character
    local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot then
        TransferBtn.Text = "❌ شخصية اللاعب غير موجودة"
        task.delay(2, function() TransferBtn.Text = "📤 نقل الكرة للاعب" end)
        return
    end

    -- تقريب الكرة فجأة للاعب الثاني
    pcall(function()
        ballPath.CFrame = targetRoot.CFrame + Vector3.new(0, 1, 0)
    end)

    transferTarget = target
    TransferBtn.Text = "✅ عند: " .. name
end)

