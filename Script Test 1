    if obj.Anchored then return false end
    if obj.Massless then return false end
    if obj == AnchorPart then return false end
    if obj.Name == "Handle" then return false end
    if obj.Parent and obj.Parent:IsA("Tool") then return false end
    if obj.Size.X * obj.Size.Y * obj.Size.Z < 0.005 then return false end

