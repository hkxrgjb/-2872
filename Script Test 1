local function GetRingPosition(index, total, centerPos)
    local angle  = CurrentAngle + (index / total) * (2 * math.pi)
    local local3 = Vector3.new(CFG.Radius * math.cos(angle), 0, CFG.Radius * math.sin(angle))
    local tiltCF = CFrame.Angles(math.rad(CFG.TiltX), 0, math.rad(CFG.TiltZ))
    local tilted = tiltCF:VectorToWorldSpace(local3)
    return Vector3.new(centerPos.X + tilted.X, centerPos.Y + CFG.Height + tilted.Y, centerPos.Z + tilted.Z)
end


local function ForcePart(part, attachTarget)
    if not IsPhysicsPart(part) then return end

    pcall(function()
        -- تنظيف كل القوى القديمة
        for _, child in ipairs(part:GetChildren()) do
            if child:IsA("BodyMover")
            or child:IsA("RocketPropulsion")
            or child.Name == "_OrbAtt"
            or child.Name == "_OrbAlign"
            or child.Name == "_OrbTorque" then
                child:Destroy()
            end
        end

        part.CanCollide = false
        part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)

        -- Torque للدوران
        local torque = Instance.new("Torque", part)
        torque.Name   = "_OrbTorque"
        torque.Torque = Vector3.new(100000, 100000, 100000)

        -- Attachment على الجزء
        local att2 = Instance.new("Attachment", part)
        att2.Name = "_OrbAtt"
        torque.Attachment0 = att2

        -- AlignPosition يربط الجزء بـ attachTarget
        local ap = Instance.new("AlignPosition", part)
        ap.Name          = "_OrbAlign"
        ap.MaxForce      = math.huge
        ap.MaxVelocity   = math.huge
        ap.Responsiveness = 200
        ap.Attachment0   = att2
        ap.Attachment1   = attachTarget

        -- تسجيل في نظام الشبكة
        getgenv().OrbitalNetwork.RetainPart(part)
    end)
end

-- ── إنشاء Attachment مستقل لكل موقع في الحلقة ──────────────────
local function AddPartToRing(part)
    if #OrbitalParts >= CFG.MaxParts then return end
    if not IsPhysicsPart(part) then return end
    if AlreadySeen[part] then return end
    AlreadySeen[part] = true

    task.spawn(function()
        task.wait(0.05)
        if not RingActive then return end
        if not part or not part.Parent then return end
        if not IsPhysicsPart(part) then return end

        -- كل جزء له Attachment خاص به على AnchorPart
        local personalAtt = Instance.new("Attachment", AnchorPart)
        personalAtt.Name = "_OrbPos_" .. tostring(#OrbitalParts + 1)

        ForcePart(part, personalAtt)

        table.insert(OrbitalParts, {
            part       = part,
            attachment = personalAtt,
        })
    end)
end

local function CleanupRing()
    -- تنظيف كل الـ attachments والـ movers
    for _, entry in ipairs(OrbitalParts) do
        pcall(function()
            if entry.attachment and entry.attachment.Parent then
                entry.attachment:Destroy()
            end
            if entry.part and entry.part.Parent then
                for _, child in ipairs(entry.part:GetChildren()) do
                    if child.Name == "_OrbAtt"
                    or child.Name == "_OrbAlign"
                    or child.Name == "_OrbTorque" then
                        child:Destroy()
                    end
                end
            end
        end)
    end
    OrbitalParts = {}
    AlreadySeen  = {}
    getgenv().OrbitalNetwork.BaseParts = {}

    if HeartbeatConn then HeartbeatConn:Disconnect() HeartbeatConn = nil end
    if DescConn       then DescConn:Disconnect()       DescConn = nil       end
end

local function StartRing()
    if RingActive then return end
    RingActive = true
    AlreadySeen = {}

    local filtered = GetFilteredParts()
    local toAdd    = math.min(#filtered, CFG.MaxParts)
    for i = 1, toAdd do AddPartToRing(filtered[i]) end

    -- ── Heartbeat: تحريك الـ Attachments في مسار الحلقة ─────────
    -- الـ AlignPosition يتبع الـ Attachment تلقائياً → فيزياء حقيقية
    HeartbeatConn = RunService.Heartbeat:Connect(function(dt)
        local centerPos = GetTargetHeadPos()
        if not centerPos then return end

        -- تحديث موضع AnchorPart ليتبع الهدف
        pcall(function()
            AnchorPart.CFrame = CFrame.new(centerPos)
        end)

        CurrentAngle = (CurrentAngle + CFG.Speed * dt) % (2 * math.pi)

        local total = #OrbitalParts
        if total == 0 then return end

        for i = #OrbitalParts, 1, -1 do
            local entry = OrbitalParts[i]
            if not entry.part or not entry.part.Parent
            or not entry.attachment or not entry.attachment.Parent then
                -- تنظيف entry ميت
                pcall(function()
                    if entry.attachment and entry.attachment.Parent then
                        entry.attachment:Destroy()
                    end
                end)
                table.remove(OrbitalParts, i)
            else
                -- نحرّك الـ Attachment إلى موقع الحلقة
                local targetPos = GetRingPosition(i, total, centerPos)
                pcall(function()
                    entry.attachment.WorldPosition = targetPos
                end)
            end
        end
    end)

    -- ── إضافة parts جديدة تلقائياً ──────────────────────────────
    task.spawn(function()
        while RingActive do
            task.wait(0.8)
            if not RingActive then break end
            if #OrbitalParts >= CFG.MaxParts then task.wait(2) continue end
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if not RingActive then break end
                if #OrbitalParts >= CFG.MaxParts then break end
                if AlreadySeen[obj] then continue end
                if IsPhysicsPart(obj) then
                    AddPartToRing(obj)
                end
            end
        end
    end)

    DescConn = Workspace.DescendantAdded:Connect(function(obj)
        if not RingActive then return end
        if #OrbitalParts >= CFG.MaxParts then return end
        if AlreadySeen[obj] then return end
        task.wait(0.15)
        if not RingActive then return end
        if IsPhysicsPart(obj) then
            AddPartToRing(obj)
        end
    end)
end

local function StopRing()
    if not RingActive then return end
    RingActive = false
    TargetPlayer = nil
    CleanupRing()
end

