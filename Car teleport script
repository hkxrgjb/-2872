            local car, primary, seat = getPrimary()

            if not car then
                local orig = tpCarBtn.Text
                tpCarBtn.Text = L.err_ride
                task.delay(1.5, function() tpCarBtn.Text = orig end)
                return
            end
            if not savedCarPos then
                local orig = tpCarBtn.Text
                tpCarBtn.Text = L.err_save
                task.delay(1.5, function() tpCarBtn.Text = orig end)
                return
            end

            isTeleporting = true
            tpCarBtn.Text = L.teleporting

            local wasFlying = flying
            flying = false
            if currentBV then currentBV.Velocity = Vector3.new(0,0,0) end
            task.wait(0.05)

            local boundsCenter, boundsSize = getCarWorldBounds(car)

            local overlapParams = OverlapParams.new()
            overlapParams.FilterType = Enum.RaycastFilterType.Exclude
            overlapParams.FilterDescendantsInstances = {car, LocalPlayer.Character}

            local looseParts = workspace:GetPartBoundsInBox(boundsCenter, boundsSize, overlapParams)

            local itemData = {}
            for _, part in ipairs(looseParts) do
                if part:IsA("BasePart") and not part.Anchored then
                    table.insert(itemData, {part = part, offset = primary.CFrame:Inverse() * part.CFrame})
                    part.Anchored = true
                end
            end

            local carParts = {}
            for _, part in ipairs(car:GetDescendants()) do
                if part:IsA("BasePart") then
                    table.insert(carParts, {part = part, originalAnchored = part.Anchored})
                    part.Anchored = true
                end
            end

            car:PivotTo(savedCarPos)
            task.wait(0.05)

            for _, data in ipairs(itemData) do
                if data.part.Parent then
                    data.part.CFrame = primary.CFrame * data.offset
                end
            end

            tpCarBtn.Text = L.locking
            task.wait(1)

            for _, data in ipairs(carParts) do
                if data.part.Parent then data.part.Anchored = data.originalAnchored end
            end
            for _, data in ipairs(itemData) do
                if data.part.Parent then data.part.Anchored = false end
            end

            for _, part in ipairs(car:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.AssemblyLinearVelocity  = Vector3.new(0,0,0)
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end

            flying = wasFlying
            isTeleporting = false
            tpCarBtn.Text = L.tp_car
        end)

        local dragging, dragStart, panelStart = false, nil, nil
        header.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                dragging   = true
                dragStart  = inp.Position
                panelStart = panel.Position
            end
        end)
        UIS.InputChanged:Connect(function(inp)
            if not dragging then return end
            if inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch then
                local d = inp.Position - dragStart
                panel.Position = UDim2.new(
                    panelStart.X.Scale, panelStart.X.Offset + d.X,
                    panelStart.Y.Scale, panelStart.Y.Offset + d.Y
                )
            end
        end)
        UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
    end

    arBtn.Activated:Connect(function() buildMainPanel("ar") end)
    enBtn.Activated:Connect(function() buildMainPanel("en") end)
end

