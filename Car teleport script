local function findCarModel(instance)
    local cur = instance
    while cur do
        if cur:IsA("Model") and cur:FindFirstChild("DriveSeat") then
            return cur
        end
        cur = cur.Parent
    end
    return nil
end

local function isPartOfAnotherCar(part, myCar)
    local car = findCarModel(part)
    return car ~= nil and car ~= myCar
end

local function getDetectionBounds(car)
    local refPart = car.PrimaryPart
    if not (refPart and refPart:IsA("BasePart")) then
        for _, v in ipairs(car:GetDescendants()) do
            if v:IsA("BasePart") then
                refPart = v
                break
            end
        end
    end
    if not refPart then return nil, nil end

    local refCF = refPart.CFrame

    local minLocal = Vector3.new(math.huge, math.huge, math.huge)
    local maxLocal = Vector3.new(-math.huge, -math.huge, -math.huge)

    for _, p in ipairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            local relCF = refCF:ToObjectSpace(p.CFrame)
            local h = p.Size * 0.5
            for x = -1,1,2 do
                for y = -1,1,2 do
                    for z = -1,1,2 do
                        local corner = relCF * CFrame.new(x*h.X, y*h.Y, z*h.Z)
                        local pos = corner.Position
                        if pos.X < minLocal.X then minLocal = Vector3.new(pos.X, minLocal.Y, minLocal.Z) end
                        if pos.Y < minLocal.Y then minLocal = Vector3.new(minLocal.X, pos.Y, minLocal.Z) end
                        if pos.Z < minLocal.Z then minLocal = Vector3.new(minLocal.X, minLocal.Y, pos.Z) end
                        if pos.X > maxLocal.X then maxLocal = Vector3.new(pos.X, maxLocal.Y, maxLocal.Z) end
                        if pos.Y > maxLocal.Y then maxLocal = Vector3.new(maxLocal.X, pos.Y, maxLocal.Z) end
                        if pos.Z > maxLocal.Z then maxLocal = Vector3.new(maxLocal.X, maxLocal.Y, pos.Z) end
                    end
                end
            end
        end
    end

    minLocal -= Vector3.new(PADDING.Left, PADDING.Bottom, PADDING.Front)
    maxLocal += Vector3.new(PADDING.Right, PADDING.Top, PADDING.Back)

    local size = maxLocal - minLocal
    if size.X <= 0 or size.Y <= 0 or size.Z <= 0 then
        return nil, nil
    end

    local centerLocal = (minLocal + maxLocal) / 2
    local worldCenter = refCF:PointToWorldSpace(centerLocal)
    local cframe = CFrame.new(worldCenter) * refCF.Rotation
    return cframe, size
end

local function getCarItems(car, primary)
    if not primary then return {} end

    local detectionCF, detectionSize = getDetectionBounds(car)
    if not detectionCF then return {} end

    local overlapParams = OverlapParams.new()
    overlapParams.FilterType = Enum.RaycastFilterType.Exclude
    overlapParams.FilterDescendantsInstances = {car, LocalPlayer.Character}

    local looseParts = workspace:GetPartBoundsInBox(detectionCF, detectionSize, overlapParams)

    local itemData = {}
    for _, part in ipairs(looseParts) do
        if part:IsA("BasePart") and not part.Anchored
            and not isPartOfAnotherCar(part, car) then
            table.insert(itemData, {
                part   = part,
                offset = primary.CFrame:Inverse() * part.CFrame,
            })
            part.Anchored = true
        end
    end
    return itemData
end

local function getPrimary()
    local char = LocalPlayer.Character
    if not char then return nil, nil, nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil, nil, nil end
    local seat = hum.SeatPart
    if not (seat and seat:IsA("VehicleSeat")) then return nil, nil, nil end
    local car = findCarModel(seat) or seat.Parent
    if not (car and car:IsA("Model")) then return nil, nil, nil end
    return car, car.PrimaryPart or seat, seat
end

local function getDriverSeat(car)
    return car:FindFirstChild("DriveSeat") or car:FindFirstChildWhichIsA("VehicleSeat")
end

local function hideAllSeats(car)
    local saved = {}
    for _, v in ipairs(car:GetDescendants()) do
        if v:IsA("VehicleSeat") then
            saved[#saved+1] = {seat=v, parent=v.Parent}
            v.Parent = seatHolder
        end
    end
    return saved
end

local function hideOtherSeats(car, exceptSeat)
    local saved = {}
    for _, v in ipairs(car:GetDescendants()) do
        if v:IsA("VehicleSeat") and v ~= exceptSeat then
            saved[#saved+1] = {seat=v, parent=v.Parent}
            v.Parent = seatHolder
        end
    end
    return saved
end

local function restoreSeats(saved)
    for _, d in ipairs(saved) do
        if d.seat and d.seat.Parent == seatHolder then
            d.seat.Parent = d.parent
        end
    end
end

local function removeSeatWeld(char)
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local seat = hum and hum.SeatPart
    if not root then return end
    if seat then
        for _, inst in ipairs(seat:GetChildren()) do
            if inst.Name == "SeatWeld" then inst:Destroy() end
        end
    end
    for _, inst in ipairs(root:GetChildren()) do
        if inst.Name == "SeatWeld" then inst:Destroy() end
    end
    task.wait(0.05)
    local humCheck = char:FindFirstChildOfClass("Humanoid")
    if humCheck and humCheck.SeatPart and root then
        root.CFrame = humCheck.SeatPart.CFrame * CFrame.new(0, 5, 3)
    end
end

local function highlightCar(car)
    if selBoxes[car] then return end
    local refCF, refSize = getDetectionBounds(car)
    if not refCF then return end

    local boxPart = Instance.new("Part")
    boxPart.Name = "SelectionPart"
    boxPart.Size = refSize
    boxPart.CFrame = refCF
    boxPart.Transparency = 1
    boxPart.CanCollide = false
    boxPart.Anchored = true
    boxPart.Parent = workspace

    local sb = Instance.new("SelectionBox")
    sb.Adornee = boxPart
    sb.Color3 = Color3.fromRGB(140, 80, 255)
    sb.LineThickness = 0.07
    sb.SurfaceTransparency = 0.80
    sb.SurfaceColor3 = Color3.fromRGB(120, 60, 220)
    sb.Parent = workspace
    selBoxes[car] = {box = sb, part = boxPart}
end

local function unhighlightCar(car)
    local data = selBoxes[car]
    if data then
        data.box:Destroy()
        data.part:Destroy()
        selBoxes[car] = nil
    end
end

local function clearSelection()
    for _, c in ipairs(selectedCars) do
        unhighlightCar(c)
        selectedSeats[c] = nil
    end
    selectedCars = {}
end

local function getSlotCFrame(car)
    if not autoTpLocation then return nil end
    if not carSlots[car] then
        local maxSlot = -1
        for _, slot in pairs(carSlots) do
            if slot > maxSlot then
                maxSlot = slot
            end
        end
        carSlots[car] = maxSlot + 1
    end
    return autoTpLocation * CFrame.new(carSlots[car] * SLOT_WIDTH, 0, 0)
end

local function teleportCarTo(car, targetCF)
    local primary = car.PrimaryPart or getDriverSeat(car)

    local itemData = getCarItems(car, primary)

    local partsData = {}
    for _, p in ipairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            table.insert(partsData, {part=p, anchored=p.Anchored})
            p.Anchored = true
        end
    end

    car:PivotTo(targetCF)
    task.wait(0.3)

    if primary and primary.Parent then
        for _, data in ipairs(itemData) do
            if data.part.Parent then
                data.part.CFrame = primary.CFrame * data.offset
            end
        end
    end

    for _, d in ipairs(partsData) do
        if d.part.Parent then d.part.Anchored = d.anchored end
    end
    for _, data in ipairs(itemData) do
        if data.part.Parent then data.part.Anchored = false end
    end

    for _, p in ipairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            p.AssemblyLinearVelocity  = Vector3.new(0,0,0)
            p.AssemblyAngularVelocity = Vector3.new(0,0,0)
        end
    end
end

local function doAutoTp(car)
    if autoTpRunning or not autoTpLocation then return end
    autoTpRunning = true

    local char  = LocalPlayer.Character
    local root  = char and char:FindFirstChild("HumanoidRootPart")
    local preCF = root and root.CFrame

    local targetCF = getSlotCFrame(car)
    if not targetCF then autoTpRunning = false; return end

    teleportCarTo(car, targetCF)

    local hiddenSeats = hideAllSeats(car)
    removeSeatWeld(char)

    local exitWait = 0
    while exitWait < 3 do
        task.wait(0.1); exitWait += 0.1
        local h = char and char:FindFirstChildOfClass("Humanoid")
        if not (h and h.SeatPart) then break end
    end

    root = char and char:FindFirstChild("HumanoidRootPart")
    if root and preCF then root.CFrame = preCF end

    restoreSeats(hiddenSeats)
    autoTpRunning = false
end

local function processQueue(onDone)
    if autoTpRunning or not autoTpLocation or #selectedCars == 0 then
        if onDone then onDone(false) end
        return
    end
    autoTpRunning = true

    local char       = LocalPlayer.Character
    local root       = char and char:FindFirstChild("HumanoidRootPart")
    local originalCF = root and root.CFrame

    local queue      = {table.unpack(selectedCars)}
    local queueSeats = {}
    for _, c in ipairs(queue) do queueSeats[c] = selectedSeats[c] end
    clearSelection()

    for _, car in ipairs(queue) do
        if not car or not car.Parent then continue end

        local seat = queueSeats[car] or getDriverSeat(car)
        if not seat or not seat.Parent then continue end

        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then continue end

        local hiddenOthers = hideOtherSeats(car, seat)
        seat:Sit(hum)

        local waited, seated = 0, false
        while waited < 3 do
            task.wait(0.1); waited += 0.1
            local h = char and char:FindFirstChildOfClass("Humanoid")
            if h and h.SeatPart == seat then seated = true; break end
        end

        if not seated then
            restoreSeats(hiddenOthers)
            continue
        end

        local targetCF = getSlotCFrame(car)
        if targetCF then teleportCarTo(car, targetCF) end

        local seatParent = seat.Parent
        seat.Parent = seatHolder
        removeSeatWeld(char)

        local exitWait = 0
        while exitWait < 3 do
            task.wait(0.1); exitWait += 0.1
            local h = char and char:FindFirstChildOfClass("Humanoid")
            if not (h and h.SeatPart) then break end
        end

        root = char and char:FindFirstChild("HumanoidRootPart")
        if root and originalCF then root.CFrame = originalCF end
        task.wait(0.3)

        if seat and seat.Parent == seatHolder then seat.Parent = seatParent end
        restoreSeats(hiddenOthers)
    end

    autoTpRunning = false
    if onDone then onDone(true) end
end

