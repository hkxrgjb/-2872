local function tween(obj, props, dur, style, dir)
    TweenService:Create(obj, TweenInfo.new(dur or 0.35,
        style or Enum.EasingStyle.Quint,
        dir   or Enum.EasingDirection.Out), props):Play()
end

local function lighten(c)
    return Color3.fromRGB(
        math.min(c.R*255 + 28, 255),
        math.min(c.G*255 + 28, 255),
        math.min(c.B*255 + 28, 255))
end

local function darken(c)
    return Color3.fromRGB(
        math.max(c.R*255 - 18, 0),
        math.max(c.G*255 - 18, 0),
        math.max(c.B*255 - 18, 0))
end

