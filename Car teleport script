local function cleanup()
    if currentCar and currentCar.Parent then
        for _, v in ipairs(currentCar:GetDescendants()) do
            if v.Name == "FlyBV" then
                pcall(function() v:Destroy() end)
            end
        end
    end
    currentCar = nil
    currentBV  = nil
end

local function getCarWorldBounds(car)
    local minX, minY, minZ =  math.huge,  math.huge,  math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge

    for _, part in ipairs(car:GetDescendants()) do
        if part:IsA("BasePart") then
            local pos  = part.Position
            local half = part.Size * 0.5
            minX = math.min(minX, pos.X - half.X)
            minY = math.min(minY, pos.Y - half.Y)
            minZ = math.min(minZ, pos.Z - half.Z)
            maxX = math.max(maxX, pos.X + half.X)
            maxY = math.max(maxY, pos.Y + half.Y)
            maxZ = math.max(maxZ, pos.Z + half.Z)
        end
    end

    local center = Vector3.new(
        (minX + maxX) * 0.5,
        (minY + maxY) * 0.5,
        (minZ + maxZ) * 0.5
    )
    local size = Vector3.new(
        (maxX - minX) + 6,
        (maxY - minY) + 6,
        (maxZ - minZ) + 6
    )
    return CFrame.new(center), size
end

local function getPrimary()
    local char = LocalPlayer.Character
    if not char then return nil, nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil, nil end
    local seat = hum.SeatPart
    if not (seat and seat:IsA("VehicleSeat")) then return nil, nil end
    local car = seat.Parent
    local primary = car.PrimaryPart or seat
    return car, primary, seat
end

