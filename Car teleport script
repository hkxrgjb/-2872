local function getNearbyCars(centerCar)
    local centerPos = centerCar:GetPivot().Position
    local radius = 200
    local nearby = {}
    local parts = workspace:GetPartBoundsInRadius(centerPos, radius)
    local seen = {}
    for _, part in ipairs(parts) do
        local car = findCarModel(part)
        if car and car:FindFirstChild("DriveSeat") and not seen[car] then
            seen[car] = true
            table.insert(nearby, car)
        end
    end
    return nearby
end

UIS.InputBegan:Connect(function(inp, gameProcessed)
    if _isDragging or gameProcessed then return end
    if not selectMode and not selectAllMode then return end
    if inp.UserInputType ~= Enum.UserInputType.Touch
    and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

    local cam     = workspace.CurrentCamera
    local unitRay = cam:ScreenPointToRay(inp.Position.X, inp.Position.Y)

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character}

    local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, rayParams)
    if not result then return end

    local carModel = findCarModel(result.Instance)
    if not carModel then return end

    if selectAllMode then
        local nearby = getNearbyCars(carModel)
        local allSelected = true
        for _, car in ipairs(nearby) do
            if not selectedSeats[car] then
                allSelected = false
                break
            end
        end
        if allSelected then
            for _, car in ipairs(nearby) do
                for i, c in ipairs(selectedCars) do
                    if c == car then
                        table.remove(selectedCars, i)
                        break
                    end
                end
                unhighlightCar(car)
                selectedSeats[car] = nil
            end
        else
            for _, car in ipairs(nearby) do
                if not selectedSeats[car] then
                    table.insert(selectedCars, car)
                    highlightCar(car)
                    selectedSeats[car] = car:FindFirstChild("DriveSeat") or car:FindFirstChildWhichIsA("VehicleSeat")
                end
            end
        end
        return
    end

    if not selectMode then return end

    local driveSeat = carModel:FindFirstChild("DriveSeat")
    if not driveSeat then return end

    local found = false
    for i, c in ipairs(selectedCars) do
        if c == carModel then
            table.remove(selectedCars, i)
            unhighlightCar(carModel)
            selectedSeats[carModel] = nil
            found = true
            break
        end
    end
    if not found then
        table.insert(selectedCars, carModel)
        highlightCar(carModel)
        selectedSeats[carModel] = driveSeat
    end
end)

RunService.RenderStepped:Connect(function()
    local car, primary, seat = getPrimary()

    if not car then
        if currentCar then cleanup() end
        return
    end
    if not flying or isTeleporting then return end

    if currentCar ~= car then
        cleanup()
        currentCar = car
    end

    if not (currentBV and currentBV.Parent) then
        local bv = Instance.new("BodyVelocity")
        bv.Name     = "FlyBV"
        bv.MaxForce = Vector3.new(math.huge,math.huge,math.huge)
        bv.Velocity = Vector3.new(0,0,0)
        bv.Parent   = primary
        currentBV   = bv
    end

    local cam       = workspace.CurrentCamera
    local lookFull  = cam.CFrame.LookVector
    local rightFlat = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z)
    if rightFlat.Magnitude > 0.01 then rightFlat = rightFlat.Unit end

    local targetVel = (lookFull  * seat.Throttle * FLY_SPEED)
                    + (rightFlat * seat.Steer    * FLY_SPEED)
    currentBV.Velocity = currentBV.Velocity:Lerp(targetVel, SMOOTH)
end)

RunService.Heartbeat:Connect(function()
    if flying and currentCar and not isTeleporting then
        local primary = currentCar.PrimaryPart
        if primary then
            local cam      = workspace.CurrentCamera
            local lookFull = cam.CFrame.LookVector
            if lookFull.Magnitude > 0.01 then
                local pos = primary.Position
                primary.CFrame = CFrame.new(pos, pos + lookFull)
            end
        end
    end

    local char = LocalPlayer.Character
    if char then
        local hum  = char:FindFirstChildOfClass("Humanoid")
        local seat = hum and hum.SeatPart
        if seat ~= lastSeat then
            lastSeat = seat
            if seat and seat:IsA("VehicleSeat")
            and autoTpEnabled and not autoTpRunning then
                local car = findCarModel(seat) or seat.Parent
                if car then task.spawn(doAutoTp, car) end
            end
        end
    end
end)
