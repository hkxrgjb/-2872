local CustomTab = Instance.new("Frame")
CustomTab.Name = "Custom"
CustomTab.Size = UDim2.new(1, 0, 1, 0)
CustomTab.BackgroundTransparency = 1
CustomTab.Parent = TabContainer
TabFrames.Custom = CustomTab
local customScroll = createScrollFrame(CustomTab)

local CustomCmdInput = CreateTextBox(customScroll, "اكتب الأمر بدون ; ...")
local sendCmdBtn, loopCmdBtn = CreateDoubleRow(customScroll, "⚡ إرسال", Color3.fromRGB(0, 110, 180), "🔄 تكرار: OFF", Color3.fromRGB(50, 50, 55))
CreateNumberInput(customScroll, customLoopSpeed, "سرعة التكرار (ثانية):", function(v) customLoopSpeed = v end)

local loopCustom = false
sendCmdBtn.MouseButton1Click:Connect(function()
    local cmd = CustomCmdInput.Text
    if cmd ~= "" then SendCmd(";"..cmd) end
end)
loopCmdBtn.MouseButton1Click:Connect(function()
    loopCustom = not loopCustom
    loopCmdBtn.Text = loopCustom and "🔄 تكرار: ON" or "🔄 تكرار: OFF"
    task.spawn(function()
        while loopCustom do
            local cmd = CustomCmdInput.Text
            if cmd ~= "" then SendCmd(";"..cmd) end
            task.wait(customLoopSpeed)
        end
    end)
end)

switchTab("Attack")

local function ShowNotify(attackerName)
    local NotifyFrame = Instance.new("Frame")
    NotifyFrame.Size = UDim2.new(0, 260, 0, 100)
    NotifyFrame.Position = UDim2.new(0.5, -130, 0.5, -50)
    NotifyFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    NotifyFrame.BorderSizePixel = 0
    NotifyFrame.Parent = ScreenGui
    Instance.new("UICorner", NotifyFrame).CornerRadius = UDim.new(0, 10)

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, -20, 0.5, 0)
    txt.Position = UDim2.new(0, 10, 0, 10)
    txt.Text = "⚠️ تم كشف مهاجم: " .. attackerName .. "\nهل تريد الرد بقسوة؟"
    txt.TextColor3 = Color3.new(1, 1, 1)
    txt.Font = Enum.Font.GothamBold
    txt.TextSize = 12
    txt.BackgroundTransparency = 1
    txt.Parent = NotifyFrame

    local YesBtn = Instance.new("TextButton")
    YesBtn.Size = UDim2.new(0.4, 0, 0.3, 0)
    YesBtn.Position = UDim2.new(0.08, 0, 0.6, 0)
    YesBtn.Text = "نعم 🔥"
    YesBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    YesBtn.TextColor3 = Color3.new(1, 1, 1)
    YesBtn.Font = Enum.Font.GothamBold
    YesBtn.Parent = NotifyFrame
    Instance.new("UICorner", YesBtn).CornerRadius = UDim.new(0, 6)

    local NoBtn = Instance.new("TextButton")
    NoBtn.Size = UDim2.new(0.4, 0, 0.3, 0)
    NoBtn.Position = UDim2.new(0.52, 0, 0.6, 0)
    NoBtn.Text = "لا ❌"
    NoBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 60)
    NoBtn.TextColor3 = Color3.new(1, 1, 1)
    NoBtn.Font = Enum.Font.GothamBold
    NoBtn.Parent = NotifyFrame
    Instance.new("UICorner", NoBtn).CornerRadius = UDim.new(0, 6)

    YesBtn.MouseButton1Click:Connect(function()
        TargetInput.Text = attackerName
        if not protectSelfActive then
            protectSelfActive = true
            protectSelfBtn.Text = "🛡️ حماية نفسي: نشطة"
            protectSelfBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
            task.spawn(ProtectSelfLoop)
        end
        if not autoTroll then
            autoTroll = true
            autoBtn.Text = "🔥 قصف تلقائي: ON"
            autoBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        end
        NotifyFrame:Destroy()
    end)
    NoBtn.MouseButton1Click:Connect(function() NotifyFrame:Destroy() end)
    task.delay(5, function() if NotifyFrame then NotifyFrame:Destroy() end end)
end

Players.PlayerChatted:Connect(function(_, player, message)
    if player ~= LP and (message:find(";jail") or message:find(";fling") or message:find(";kill")) then
        if message:find(LP.Name) or message:find("all") or message:find("others") then
            ShowNotify(player.Name)
        end
    end
end)
