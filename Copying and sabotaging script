local function SendCmd(msg)
    if not msg or msg == "" then return end
    pcall(function()
        local remote = RS:FindFirstChild("HDAdminHDClient")
        if remote then
            remote.Signals.RequestCommandModification:InvokeServer(msg)
        end
    end)
end

local function GetPlayer(name)
    if not name or name == "" then return nil end
    name = name:lower()
    for _, v in ipairs(Players:GetPlayers()) do
        if v.Name:lower():sub(1, #name) == name or v.DisplayName:lower():sub(1, #name) == name then
            return v.Name
        end
    end
    return nil
end

local function BuildAttackMessage(targetFull, useFullName)
    local targetStr = useFullName and targetFull or targetFull:sub(1,2)
    local parts = {}
    for _, cmd in ipairs(HDAdminCommands) do
        local repeated = ""
        for i = 1, attackMultiplier do
            repeated = repeated .. cmd .. targetStr .. " "
        end
        table.insert(parts, repeated)
    end
    table.insert(parts, ";name " .. targetStr .. " HACKED ")
    table.insert(parts, ";shirt " .. targetStr .. " 1 ")
    table.insert(parts, ";pants " .. targetStr .. " 1 ")
    return table.concat(parts)
end

local function BuildScreenSpamMessage(targetFull, useFullName)
    local targetStr = useFullName and targetFull or targetFull:sub(1,2)
    local parts = {}
    for _, cmd in ipairs(ScreenSpamCommands) do
        table.insert(parts, cmd .. targetStr)
    end
    table.insert(parts, ";re " .. targetStr)
    return table.concat(parts, " ")
end

local function GetProtectionCommands(targetFull)
    local short = (targetFull == "me") and "me" or targetFull:sub(1,2)
    local cmds = {
        ";unpunish "..short, ";unfreeze "..short, ";unjail "..short,
        ";unblind "..short, ";undog "..short, ";unice "..short,
        ";unfire "..short, ";unseizure "..short, ";unghost "..short,
        ";unbigify "..short, ";unsmallify "..short, ";unfatify "..short,
        ";unwormify "..short, ";unchibify "..short, ";unplushify "..short,
        ";unfreakify "..short, ";unfrogify "..short, ";unspongify "..short,
        ";undinofy "..short, ";unbuffify "..short,
        ";if "..short, ";kit god "..short, ";god "..short, ";ff "..short,
        ";shield "..short, ";antikick "..short, ";antijail "..short,
        ";refresh "..short, ";re "..short, ";reset "..short,
        ";unh "..short, ";unhg "..short, ";unhdg "..short, ";unhb "..short,
        ";unhdb "..short, ";unhp "..short, ";unhpk "..short, ";unhbk "..short,
    }
    return table.concat(cmds, " ")
end

local function RunChaos(useFullName)
    local name = TargetInput.Text
    local target = GetPlayer(name)
    if target then
        SendCmd(BuildAttackMessage(target, useFullName))
    end
end

local function BringVictimToMe(targetFull)
    local char = LP.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local pos = char.HumanoidRootPart.Position
    SendCmd(string.format(";tp %s %d %d %d", targetFull:sub(1,2), pos.X, pos.Y, pos.Z))
end

local function StartTeleportChaos()
    if teleportTask then task.cancel(teleportTask) end
    teleportTask = task.spawn(function()
        while teleportChaosActive do
            local target = GetPlayer(TargetInput.Text)
            if target then BringVictimToMe(target) end
            task.wait(teleportSpeed)
        end
    end)
end

local function StopTeleportChaos()
    teleportChaosActive = false
    if teleportTask then task.cancel(teleportTask) teleportTask = nil end
end

local function ProtectSelfLoop()
    while protectSelfActive do
        SendCmd(GetProtectionCommands("me"))
        task.wait(0.8)
    end
end

local function ProtectOtherLoop()
    while protectOtherActive do
        local target = GetPlayer(protectOtherName)
        if target then
            SendCmd(GetProtectionCommands(target))
        end
        task.wait(0.8)
    end
end

local function ScreenSpamLoop()
    while screenSpamActive do
        local target = GetPlayer(TargetInput.Text)
        if target then
            SendCmd(BuildScreenSpamMessage(target, true))
        end
        task.wait(screenSpamSpeed)
    end
end

