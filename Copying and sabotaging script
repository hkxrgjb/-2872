local function CreateNumberInput(parent, defaultVal, label, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.55, 0, 0, 24)
    lbl.Position = UDim2.new(0, 0, 0, 0)
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.Parent = frame

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.4, 0, 0, 24)
    box.Position = UDim2.new(0.55, 8, 0, 0)
    box.Text = tostring(defaultVal)
    box.PlaceholderText = "ثانية"
    box.BackgroundColor3 = Color3.fromRGB(38, 38, 44)
    box.TextColor3 = Color3.new(1,1,1)
    box.Font = Enum.Font.Gotham
    box.TextSize = 12
    box.Parent = frame
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)

    local warning = Instance.new("TextLabel")
    warning.Size = UDim2.new(1, 0, 0, 16)
    warning.Position = UDim2.new(0, 0, 0, 28)
    warning.Text = ""
    warning.TextColor3 = Color3.fromRGB(255, 80, 80)
    warning.BackgroundTransparency = 1
    warning.Font = Enum.Font.Gotham
    warning.TextSize = 10
    warning.Parent = frame

    local function validateAndApply()
        local num = tonumber(box.Text)
        if num and num >= 0.1 and num <= 10 then
            warning.Text = ""
            callback(num)
        else
            warning.Text = "أدخل رقم بين 0.1 و 10"
            box.Text = tostring(defaultVal)
        end
    end

    box.FocusLost:Connect(validateAndApply)
    box:GetPropertyChangedSignal("Text"):Connect(function()
    end)
    return frame
end

